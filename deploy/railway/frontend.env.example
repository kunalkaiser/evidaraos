NODE_ENV=production
NEXT_PUBLIC_STATIC_WEBSITE_ONLY=false

# Replace with the deployed gateway URL.
NEXT_PUBLIC_BACKEND_BASE_URL=https://<gateway-domain>
NEXT_PUBLIC_LANGGRAPH_BASE_URL=https://<gateway-domain>/api

# Server-side calls from Next.js to the gateway.
DEER_FLOW_INTERNAL_GATEWAY_BASE_URL=https://<gateway-domain>

# Comma-separated trusted browser origins.
DEER_FLOW_TRUSTED_ORIGINS=https://<frontend-domain>

# Generate a long random value.
BETTER_AUTH_SECRET=<replace-with-random-secret>
