CI=true
NODE_ENV=production

DEER_FLOW_PROJECT_ROOT=/app
DEER_FLOW_HOME=/app/backend/.deer-flow
DEER_FLOW_CONFIG_PATH=/app/backend/config.yaml
DEER_FLOW_EXTENSIONS_CONFIG_PATH=/app/backend/extensions_config.json
DEER_FLOW_SKILLS_PATH=/app/skills

# Public frontend domain for CORS/auth trust.
CORS_ORIGINS=https://<frontend-domain>
GATEWAY_CORS_ORIGINS=https://<frontend-domain>
DEER_FLOW_TRUSTED_ORIGINS=https://<frontend-domain>

# Generate a long random value and keep it identical with frontend.
BETTER_AUTH_SECRET=<replace-with-random-secret>

# Required for the configured default model in config.yaml.
ANTHROPIC_API_KEY=<replace-with-api-key>

# Optional literature/search providers used by evidence workflows.
SERPER_API_KEY=
TAVILY_API_KEY=
JINA_API_KEY=
INFOQUEST_API_KEY=

# Disable public API docs in production if desired.
GATEWAY_ENABLE_DOCS=false
