  "properties": {
    "fixture_only": { "type": "boolean" },
    "review_queue": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["review_item_id", "candidate_pair", "review_dimensions", "human_decision"],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
