{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvidaraOS Repurposing Knowledge Graph",
  "type": "object",
  "required": ["nodes", "edges"],
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "type"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "type": { "type": "string" },
          "sources": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target", "predicate"],
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "predicate": { "type": "string" },
          "evidence_records": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "string" },
          "human_review_required": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
