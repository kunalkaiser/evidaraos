{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PrismaSummary",
  "type": "object",
  "required": ["identified", "deduplicated", "screened", "excluded", "full_text_assessed", "final_included"],
  "properties": {
    "identified": { "type": "integer", "minimum": 0 },
    "deduplicated": { "type": "integer", "minimum": 0 },
    "screened": { "type": "integer", "minimum": 0 },
    "excluded": { "type": "integer", "minimum": 0 },
    "full_text_assessed": { "type": "integer", "minimum": 0 },
    "final_included": { "type": "integer", "minimum": 0 },
    "duplicates_removed": { "type": "integer", "minimum": 0 },
    "full_text_excluded": { "type": "integer", "minimum": 0 },
    "precision_tiers": {
      "type": "object",
      "properties": {
        "very_likely_include": { "type": "integer", "minimum": 0 },
        "possible_include": { "type": "integer", "minimum": 0 },
        "uncertain_human_review": { "type": "integer", "minimum": 0 },
        "likely_exclude": { "type": "integer", "minimum": 0 },
        "background_only": { "type": "integer", "minimum": 0 }
      }
    },
    "ai_prioritized_records": { "type": "integer", "minimum": 0 },
    "human_review_required_records": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
