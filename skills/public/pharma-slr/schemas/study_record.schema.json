{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StudyRecord",
  "type": "object",
  "required": ["id", "source", "title"],
  "properties": {
    "id": { "type": "string" },
    "source": { "type": "string", "enum": ["pubmed", "semantic_scholar", "crossref", "manual", "other"] },
    "title": { "type": "string" },
    "authors": { "type": "array", "items": { "type": "string" }, "default": [] },
    "abstract": { "type": "string", "default": "" },
    "journal": { "type": "string", "default": "" },
    "year": { "type": "string", "default": "" },
    "publication_date": { "type": "string", "default": "" },
    "doi": { "type": "string", "default": "" },
    "pmid": { "type": "string", "default": "" },
    "url": { "type": "string", "default": "" },
    "keywords": { "type": "array", "items": { "type": "string" }, "default": [] },
    "citationCount": { "type": ["integer", "null"] },
    "influentialCitationCount": { "type": ["integer", "null"] },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": { "type": "string" },
          "id": { "type": "string" },
          "doi": { "type": "string" },
          "pmid": { "type": "string" },
          "url": { "type": "string" }
        }
      },
      "default": []
    }
  },
  "additionalProperties": true
}
